{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "types": ["vite-plugin-svgr/client", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@app": ["./src/app"],
      "@app/*": ["./src/app/*"],
      "@api": ["./src/api"],
      "@api/*": ["./src/api/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"],
      "@assets": ["./src/assets"],
      "@assets/*": ["./src/assets/*"],
      "@interfaces": ["./src/interfaces"],
      "@interfaces/*": ["./src/interfaces/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@pages": ["./src/pages"],
      "@pages/*": ["./src/pages/*"],
      "@router": ["./src/router"],
      "@router/*": ["./src/router/*"],
      "@services": ["./src/services"],
      "@services/*": ["./src/services/*"],
      "@contexts": ["./src/contexts"],
      "@contexts/*": ["./src/contexts/*"],
      "@layouts": ["./src/layouts"],
      "@layouts/*": ["./src/layouts/*"]
    }
  }
}
